# ===========================================
# Dashboard OKSEI — переменные окружения
# Скопируйте в .env и заполните значения
# ===========================================

# --- Backend (Go) ---

# Режим: production — требует JWT_SECRET и LOGIN_PASSWORD отличные от дефолта
# APP_ENV=production

# Сервер
SERVER_HOST=localhost
SERVER_PORT=8080

# База данных PostgreSQL (если не указан DATABASE_URL — формируется из отдельных переменных)
# DATABASE_URL=postgres://user:password@localhost:5432/dashboard?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=dashboard

# JWT — ОБЯЗАТЕЛЬНО сменить в production!
JWT_SECRET=change-me-in-production

# Логин для входа (admin по умолчанию)
LOGIN_USER=admin
LOGIN_PASSWORD=admin
LOGIN_ROLE=admin

# CORS (через запятую или * для всех)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Порог пропусков для алертов (1-100)
ABSENCE_THRESHOLD=10

# Интервал автообновления данных (например: 90m, 1h30m)
REFRESH_INTERVAL=90m

# Директория с файлами 1С (шара)
ONEC_SOURCE_DIR=\\1C01\proba

# Пути к файлам (опционально, иначе из projectRoot)
# ATTENDANCE_INPUT= ATTENDANCE_OUTPUT= STATEMENT_INPUT= STATEMENT_OUTPUT=
# STUDENTS_INPUT= STUDENTS_OUTPUT= LESSONS_INPUT= LESSONS_OUTPUT= PYTHON_SCRIPT=

# --- Frontend (Vite) ---

# URL API (в dev обычно /api — прокси на бэкенд)
VITE_API_URL=/api

# URL бэкенда для dev-прокси (только для vite.config)
# VITE_PROXY_TARGET=http://localhost:8080
